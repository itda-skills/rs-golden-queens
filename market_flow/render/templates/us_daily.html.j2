{% extends "_base.html.j2" %}
{% block title %}{{ target }} 미국장 마감{% endblock %}

{# 가격 + 등락 행: 라벨 / 화살표 / 종가 / 등락률 #}
{% macro price_row(label, close, pct, prefix='') %}
  {% set cls = 'up' if pct is not none and pct > 0 else ('down' if pct is not none and pct < 0 else 'flat') %}
  {% set arr = '▲' if pct is not none and pct > 0 else ('▼' if pct is not none and pct < 0 else '–') %}
  <tr>
    <td class="label">{{ label }}</td>
    <td class="arrow {{ cls }}">{{ arr }}</td>
    <td class="value-secondary">{{ prefix }}{% if close is not none %}{{ '{:,.2f}'.format(close) }}{% else %}-{% endif %}</td>
    <td class="value {{ cls }}">{% if pct is none %}-{% elif pct >= 0 %}+{{ '{:.2f}'.format(pct) }}%{% else %}{{ '{:.2f}'.format(pct) }}%{% endif %}</td>
  </tr>
{% endmacro %}

{# 등락만 (섹터, 워치) #}
{% macro pct_row(label, pct, extra='') %}
  {% set cls = 'up' if pct is not none and pct > 0 else ('down' if pct is not none and pct < 0 else 'flat') %}
  {% set arr = '▲' if pct is not none and pct > 0 else ('▼' if pct is not none and pct < 0 else '–') %}
  <tr>
    <td class="label">{{ label }}</td>
    <td class="arrow {{ cls }}">{{ arr }}</td>
    <td class="value {{ cls }}">{% if pct is none %}-{% elif pct >= 0 %}+{{ '{:.2f}'.format(pct) }}%{% else %}{{ '{:.2f}'.format(pct) }}%{% endif %}</td>
    {% if extra %}<td class="value-secondary">{{ extra }}</td>{% endif %}
  </tr>
{% endmacro %}

{% block body %}
<header>
  <h1>🇺🇸 {{ target }} 미국장 마감</h1>
</header>

{% if indices %}
<section>
  <h2>📊 주요 지수 <span class="unit">(종가 / 등락)</span></h2>
  <table>
    {% for it in indices %}{{ price_row(it.label, it.close, it.pct) }}{% endfor %}
  </table>
</section>
{% endif %}

{% if volatility %}
<section>
  <h2>🌡 변동성·꼬리위험</h2>
  <table>
    {% for it in volatility %}{{ price_row(it.label, it.close, it.pct) }}{% endfor %}
  </table>
</section>
{% endif %}

{% if risk_label %}
<section>
  <h2>💵 위험선호 (Risk On/Off)</h2>
  <div style="display:flex; align-items:center; gap:12px; padding:6px 0;">
    <span class="badge {{ risk_cls }}">{{ risk_label }}</span>
    <span class="unit">HYG {{ '%+.2f'|format(hyg_pct) }}% / IEF {{ '%+.2f'|format(ief_pct) }}% (갭 {{ '%+.2f'|format(hyg_pct - ief_pct) }}%p)</span>
  </div>
</section>
{% endif %}

{% if macro %}
<section>
  <h2>💹 매크로</h2>
  <table>
    {% for it in macro %}{{ price_row(it.label, it.close, it.pct) }}{% endfor %}
  </table>
</section>
{% endif %}

{% if sectors %}
<section>
  <h2>💼 섹터 (S&amp;P 11) <span class="unit">(등락 정렬)</span></h2>
  <table>
    {% for it in sectors %}{{ pct_row(it.label, it.pct) }}{% endfor %}
  </table>
</section>
{% endif %}

{% if watch %}
<section>
  <h2>⭐ 워치 ETF <span class="unit">(등락 + 거래량강도, 🔥 = 1.5↑ 자금쏠림)</span></h2>
  <table>
    {% for it in watch %}
    {% set cls = 'up' if it.pct is not none and it.pct > 0 else ('down' if it.pct is not none and it.pct < 0 else 'flat') %}
    {% set arr = '▲' if it.pct is not none and it.pct > 0 else ('▼' if it.pct is not none and it.pct < 0 else '–') %}
    <tr>
      <td class="label"><b>{{ it.ticker }}</b> <span class="sub">· {{ it.label }}</span></td>
      <td class="arrow {{ cls }}">{{ arr }}</td>
      <td class="value-secondary">${{ '{:,.2f}'.format(it.close) }}</td>
      <td class="value {{ cls }}">{% if it.pct >= 0 %}+{% endif %}{{ '{:.2f}'.format(it.pct) }}%</td>
      <td class="value-secondary">{{ it.vol_str }}{% if it.hot %} <span class="accent">🔥</span>{% endif %}</td>
    </tr>
    {% endfor %}
  </table>
</section>
{% endif %}
{% endblock %}
